---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrap footer-inner">
    <div class="footer-brand">
      <p class="brand-title">KUBANY, LLC</p>
      <p class="brand-tagline">Strategic Communications for Art, Architecture & Design</p>
    </div>
    
    <div class="footer-links-grid">
      <div class="footer-col">
        <p class="col-title">Inquiries</p>
        <a href="mailto:elizabeth@kubany.co" class="footer-link animated-underline">elizabeth@kubany.co</a>
      </div>
      
      <div class="footer-col">
        <p class="col-title">Follow</p>
        <div class="social-links">
          <a href="https://www.instagram.com/elizabethkubany/" target="_blank" rel="noopener noreferrer" class="footer-link animated-underline">Instagram</a>
          <a href="https://www.linkedin.com/in/lizkubany/" target="_blank" rel="noopener noreferrer" class="footer-link animated-underline">LinkedIn</a>
        </div>
      </div>
    </div>
  </div>
  
  <div class="wrap footer-bottom">
    <p class="copyright">&copy; {currentYear} KUBANY, LLC. All rights reserved.</p>
    <p class="credit">Website designed in NYC</p>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--sand-light);
    border-top: 1px solid var(--border-color);
    padding-top: clamp(3rem, 6vw, 5rem);
    padding-bottom: 2rem;
    color: var(--text-color);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 3rem;
    flex-wrap: wrap;
    margin-bottom: clamp(2rem, 5vw, 4rem);
  }

  .footer-brand {
    flex: 1 1 300px;
  }

  .brand-title {
    font-family: var(--font-serif);
    font-size: var(--step-1);
    color: var(--header-color);
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  .brand-tagline {
    font-size: var(--step--1);
    color: var(--text-color);
    opacity: 0.8;
    max-width: 30ch;
  }

  .footer-links-grid {
    display: flex;
    gap: clamp(2rem, 6vw, 5rem);
    flex-wrap: wrap;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .col-title {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--sand-color);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }

  .footer-link {
    font-size: var(--step--1);
    color: var(--text-color);
  }

  .footer-link:hover {
    color: var(--header-color);
  }

  .social-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid rgba(61, 82, 69, 0.08);
    padding-top: 1.5rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .copyright, .credit {
    font-size: var(--step--2);
    color: var(--text-color);
    opacity: 0.6;
  }

  @media (max-width: 48rem) {
    .footer-inner {
      flex-direction: column;
      gap: 2rem;
    }
  }
</style>
