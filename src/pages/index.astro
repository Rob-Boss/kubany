    object-fit: cover;
  }

  .overlay-gallery-caption {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--sand-color);
    font-style: italic;
  }

  /* Navigation button */
  .overlay-project-nav {
    border-top: 1px solid var(--border-color);
    padding-top: 2rem;
  }

  .next-link-btn {
    background: none;
    border: none;
    padding: 0;
    font-family: var(--font-serif);
    font-size: var(--step-1);
    color: var(--header-color);
    cursor: pointer;
    font-weight: 400;
  }

  /* Mobile responsive styling overrides */
  @media (max-width: 48rem) {
    .portfolio-split-layout {
      flex-direction: column !important;
      gap: 2rem;
    }

    .bio-split-layout {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .boards-list {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }

    .case-study-overlay {
      width: 100%;
      height: 100vh;
      max-height: 100vh;
    }

    .overlay-card {
      width: 100%;
      height: 100vh;
      max-height: 100vh;
      border: none;
    }

    .overlay-inner {
      padding: 1.5rem;
      padding-top: 4.5rem;
    }

    .overlay-close-btn {
      top: 1rem;
      right: 1rem;
      font-size: 2.5rem;
    }

    .overlay-content-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .overlay-grid-left {
      position: static;
    }

    .overlay-gallery-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    
    .portfolio-right-col {
      display: none !important;
    }

    .pullquote-band {
      display: block;
      background-color: var(--header-color);
      color: var(--bg-color);
      text-align: center;
      padding-block: 4rem;
    }
    
    .pullquote-container {
      width: 90%;
      margin-inline: auto;
    }
    
    .pullquote-text {
      font-family: var(--font-serif);
      font-size: var(--step-2);
      font-style: italic;
    }
    
    .work-menu-link:hover {
      padding-left: 0;
    }

    /* On mobile, poster lines stack simply */
    .poster-line {
      padding-inline: 1.25rem;
    }

    .poster-desc {
      opacity: 0.85;
      max-height: 6rem;
    }
  }
</style>

<script>
  // 1. Dynamic Hover-Revealed Project Circular Image Script
  function setupProjectBgHover() {
    document.querySelectorAll('[data-project-hover]').forEach((el) => {
      const slug = el.getAttribute('data-project-hover');
      const frame = document.getElementById(`frame-${slug}`);

      if (!frame) return;

      el.addEventListener('mouseenter', () => {
        frame.classList.add('active');
      });

      el.addEventListener('mouseleave', () => {
        frame.classList.remove('active');
      });
    });
  }

  // 2. Folio Accordion Toggle Script
  function setupFolioAccordion() {
    const columns = document.querySelectorAll('.canvas-column');
    
    columns.forEach((col) => {
      col.addEventListener('click', (e) => {
        // If clicking a link/button/interactive element inside the active column, do nothing
        if (col.classList.contains('active')) {
          return;
        }

        // Deactivate other columns
        columns.forEach((c) => c.classList.remove('active'));
        
        // Activate this column
        col.classList.add('active');
      });
    });
  }

  // 3. Folio URL Parameter Routing Script
  function routeFolioPanes() {
    const params = new URLSearchParams(window.location.search);
    const target = params.get('pane');
    if (!target) return;

    const paneMap: Record<string, string> = {
      'portfolio': '.pane-work',
      'services': '.pane-services',
      'about': '.pane-bio',
      'contact': '.pane-contact'
    };

    const targetClass = paneMap[target.toLowerCase()];
    if (!targetClass) return;

    const columns = document.querySelectorAll('.canvas-column');
    const targetCol = document.querySelector(targetClass);

    if (targetCol && !targetCol.classList.contains('active')) {
      columns.forEach((c) => c.classList.remove('active'));
      targetCol.classList.add('active');
      
      // Wait for intro shutter split before scrolling into focus
      setTimeout(() => {
        targetCol.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
      }, 1800);
    }
  }

  // 4. SVG Connector Line Drawing Script
  function setupConnectorLines() {
    const layout = document.querySelector('.portfolio-split-layout');
    const svg = document.getElementById('portfolio-connector-svg');
    const path = document.getElementById('connector-path');
    const links = document.querySelectorAll('[data-project-hover]');
    const rightCol = document.querySelector('.portfolio-right-col');

    if (!layout || !svg || !path || !rightCol) return;

    let animFrameId: number | null = null;

    function updatePath(el: HTMLElement) {
      if (window.innerWidth <= 768) {
        clearPath();
        return;
      }

      const layoutRect = layout!.getBoundingClientRect();
      const rightColRect = rightCol!.getBoundingClientRect();
      const nameEl = el.querySelector('.project-name');
      if (!nameEl) return;

      const nameRect = nameEl.getBoundingClientRect();

      // starts 12px to the right of the actual text boundary
      const x1 = nameRect.right - layoutRect.left + 12;
      const y1 = (nameRect.top + nameRect.bottom) / 2 - layoutRect.top;

      // The circle left edge is statically positioned exactly 16px to the right of the rightCol boundary.
      // We point 10px to the left of the circle edge (which is at +16px).
      const x2 = rightColRect.left - layoutRect.left + 16 - 10;
      const y2 = (rightColRect.top + rightColRect.bottom) / 2 - layoutRect.top;

      // Orthogonal connector path: goes horizontally halfway, bends 90 deg vertically, and then horizontally to the target
      const x_mid = x1 + (x2 - x1) * 0.45;

      const d = `M ${x1} ${y1} H ${x_mid} V ${y2} H ${x2}`;
      path!.setAttribute('d', d);

      // Measure SVG path length
      const length = (path as any).getTotalLength();
      const pathStyle = (path as HTMLElement).style;
      
      // Set starting dasharray & dashoffset to full path length
      pathStyle.strokeDasharray = `${length}`;
      pathStyle.strokeDashoffset = `${length}`;
      path!.classList.add('active');

      // Cancel any pending animation frames
      if (animFrameId) cancelAnimationFrame(animFrameId);

      // Force drawing animation on the next paint cycle
      animFrameId = requestAnimationFrame(() => {
        animFrameId = requestAnimationFrame(() => {
          pathStyle.strokeDashoffset = '0';
        });
      });
    }

    function clearPath() {
      if (animFrameId) cancelAnimationFrame(animFrameId);
      path!.classList.remove('active');
    }

    links.forEach((link) => {
      link.addEventListener('mouseenter', () => updatePath(link as HTMLElement));
      link.addEventListener('mouseleave', clearPath);
    });
  }

  // 5. (Services poster is now pure CSS — no JS needed)

  // 5. Case Study Overlay Modal Controls
  function setupCaseStudyOverlays() {
    const studySlugs = Array.from(document.querySelectorAll('.case-study-overlay')).map(el => el.id.replace('overlay-', ''));

    // Intercept project clicks
    document.querySelectorAll('.work-menu-link').forEach((link) => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const slug = link.getAttribute('data-project-hover');
        if (!slug) return;
        
        openOverlay(slug);
      });
    });

    // Handle close buttons
    document.querySelectorAll('[data-close-overlay]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const overlay = btn.closest('.case-study-overlay');
        if (overlay) {
          overlay.classList.remove('active');
          document.body.classList.remove('has-overlay-active');
          // Remove query param without reload
          const url = new URL(window.location.href);
          url.searchParams.delete('project');
          window.history.pushState({}, '', url);
        }
      });
    });

    // Handle next project buttons
    document.querySelectorAll('[data-next-project]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const nextSlug = btn.getAttribute('data-next-project');
        const currentOverlay = btn.closest('.case-study-overlay');
        if (currentOverlay) {
          currentOverlay.classList.remove('active');
        }
        if (nextSlug) {
          openOverlay(nextSlug);
        }
      });
    });

    // Helper to open overlay
    function openOverlay(slug) {
      const overlay = document.getElementById('overlay-' + slug);
      if (overlay) {
        overlay.classList.add('active');
        document.body.classList.add('has-overlay-active');
        // Update URL query param without reload
        const url = new URL(window.location.href);
        url.searchParams.set('project', slug);
        window.history.pushState({}, '', url);
      }
    }

    // Keyboard controls: Escape & Left/Right Arrows
    function handleKeydown(e) {
      const activeOverlay = document.querySelector('.case-study-overlay.active');
      if (!activeOverlay) return;

      if (e.key === 'Escape') {
        activeOverlay.classList.remove('active');
        document.body.classList.remove('has-overlay-active');
        const url = new URL(window.location.href);
        url.searchParams.delete('project');
        window.history.pushState({}, '', url);
      } else if (e.key === 'ArrowRight' || e.key === 'ArrowLeft') {
        const currentSlug = activeOverlay.id.replace('overlay-', '');
        const index = studySlugs.indexOf(currentSlug);
        if (index === -1) return;

        let nextIndex;
        if (e.key === 'ArrowRight') {
          nextIndex = (index + 1) % studySlugs.length;
        } else {
          nextIndex = (index - 1 + studySlugs.length) % studySlugs.length;
        }

        activeOverlay.classList.remove('active');
        openOverlay(studySlugs[nextIndex]);
      }
    }

    window.removeEventListener('keydown', handleKeydown);
    window.addEventListener('keydown', handleKeydown);

    // Auto-open if query param exists on load
    const params = new URLSearchParams(window.location.search);
    const initialProject = params.get('project');
    if (initialProject) {
      setTimeout(() => {
        openOverlay(initialProject);
      }, 500);
    }
  }

  function setupFolioKeyboardControls() {
    const columns = Array.from(document.querySelectorAll('.canvas-column'));
    const brandCol = document.querySelector('.pane-brand');

    function handleKeyDown(e) {
      // ONLY run if no overlay is active!
      const activeOverlay = document.querySelector('.case-study-overlay.active');
      if (activeOverlay) return;

      if (e.key === 'ArrowRight' || e.key === 'ArrowLeft') {
        const activeCol = document.querySelector('.canvas-column.active');
        if (!activeCol) return;

        const index = columns.indexOf(activeCol);
        if (index === -1) return;

        let nextIndex;
        if (e.key === 'ArrowRight') {
          nextIndex = (index + 1) % columns.length;
        } else {
          nextIndex = (index - 1 + columns.length) % columns.length;
        }

        const targetCol = columns[nextIndex];
        if (targetCol) {
          columns.forEach((c) => c.classList.remove('active'));
          targetCol.classList.add('active');
          targetCol.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
        }
      } else if (e.key === 'Escape') {
        if (brandCol && !brandCol.classList.contains('active')) {
          columns.forEach((c) => c.classList.remove('active'));
          brandCol.classList.add('active');
          brandCol.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
        }
      }
    }

    window.removeEventListener('keydown', handleKeyDown);
    window.addEventListener('keydown', handleKeyDown);
  }

  // Bind initial interactions
  setupProjectBgHover();
  setupFolioAccordion();
  routeFolioPanes();
  setupConnectorLines();
  setupCaseStudyOverlays();
  setupFolioKeyboardControls();

  // Re-bind bindings after Astro page swaps
  document.addEventListener('astro:after-swap', () => {
    setupProjectBgHover();
    setupFolioAccordion();
    routeFolioPanes();
    setupConnectorLines();
    setupCaseStudyOverlays();
    setupFolioKeyboardControls();
  });
</script>
