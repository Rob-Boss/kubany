  }

  /* Content Grid Layout */
  .overlay-content-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    align-items: start;
  }

  .overlay-grid-left {
    display: flex;
    flex-direction: column;
