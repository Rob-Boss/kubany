---
import BaseLayout from '../layouts/BaseLayout.astro';
import { caseStudies } from '../data/caseStudies';

// Verbatim copy from KUBANY brand assets
const headline =
  "The common thread in all of our work is the profound belief in the power of beauty in the built and designed environment to improve the world.";
const mission =
  "KUBANY is a strategic communications agency founded on the principle that a better designed environment benefits us all.";
const positioning =
  "By heightening the dialogue around culture, beauty and design, KUBANY believes that these topics will then become an indelible part of contemporary discourse. Deeply rooted in culture and savvy about the media, KUBANY has a long history of creating and communicating powerful ideas.";

const servicesIntro =
  "Your brand is an ecosystem. Public relations is no longer enough on its own. We are a full-service communications firm with capabilities across traditional public relations, communications, content creation, creative strategy and social media/digital strategy that considers every aspect of your brand platform in formulating an approach.";

const services = [
  { 
    id: "01",
    title: "Communications & Media Relations", 
    body: "Rivaling agencies many times our size, KUBANY excels at creating and executing fully integrated communications campaigns that influence audiences locally, nationally, and internationally. KUBANY looks well beyond the marquis print placement to create a strategic plan based in storytelling and brand building that produces careful ubiquity on all platforms and advances our clients' mission and goals." 
  },
  { 
    id: "02",
    title: "Social Media & Online Strategy", 
    body: "Social media is no longer optional. We approach social media engagement as a vital and integral part of any communications strategy. From social media audits to strategic social media plans that deepen and broaden engagement to influencer marketing, KUBANY understands the power of these platforms to build an audience." 
  },
  { 
    id: "03",
    title: "Marketing & Brand Engagement", 
    body: "Great press is just part of the picture. In a noisy world, those brands that are highly disciplined about their messages are the ones that prevail. Therefore, every aspect of engagement — from marketing to communications to internal communications — should be coordinated in terms of language and strategy." 
  },
  { 
    id: "04",
    title: "Partnerships & Creative Services", 
    body: "With a creative spirit and a broad-based awareness of the cultural landscape and marketplace, KUBANY makes connections and forges partnerships to further the goals of brands, institutions, and firms." 
  },
  { 
    id: "05",
    title: "Content Creation & Editorial", 
    body: "We still believe that words matter and that a rigorous set of messages, disseminated through a variety of platforms, is the best way to achieve broad awareness. Our work encompasses press materials, message development, speeches, bylined articles, white papers, op-eds, and promotional materials." 
  },
  { 
    id: "06",
    title: "Crisis Communications", 
    body: "Within every crisis, lies the possibility of opportunity. We are expert in guiding clients through crises in a way that reinforces credibility and enhances trust so that they emerge strong." 
  },
  { 
    id: "07",
    title: "Media Training", 
    body: "The ability to communicate your messages is critical to this work. We can brush up your skills, or teach you new ones, to help you share your story more effectively." 
  },
  { 
    id: "08",
    title: "Awards & Thought Leadership", 
    body: "Awards, photography, video, speaking engagements, thought leadership, and more — KUBANY has experience working across all of these topics to ensure a thoughtfully crafted brand story." 
  },
];

const bioLead =
  "Elizabeth Kubany’s work begins with her lifelong belief in the power of architecture, design, and art to make the world a better, more beautiful, and more equitable place. For more than two decades, her work in communications has reflected this profound passion for all aspects of visual culture. She has been an engaged and informed participant in the cultural community for years and possesses a breadth and depth of awareness that has proven invaluable to her clients.";

const bioRest = [
  "Her client roster is an international group that includes cultural institutions and foundations, art galleries, architects, developers, designers of all types, and artists, but the work itself is based on relationships – both with her clients and the media. The merging of intimate client connections and her long-standing media networks, with her deep expertise in the subject matter, enable Liz to tell her partners’ stories strategically and with nuance that extends far beyond press releases, sound bites, or bullet points.",
  "Liz defines public relations in the broadest way possible – including all aspects of communication, digital and social media strategy, brand awareness, and market penetration and expansion – all within the context of business development. Ultimately her success is inextricably tied to her clients’ success.",
  "She studied architecture and art/architectural history as an undergraduate at Columbia College and received her Master’s degree in architectural history and theory from the Architectural Association in London. Liz currently serves on the boards of the National Academy of Design, Open House New York, The New York Review of Architecture and Archnative.com."
];

const boards = [
  "National Academy of Design",
  "Open House New York",
  "The New York Review of Architecture",
  "Archnative.com"
];
---

<BaseLayout 
  title="KUBANY — Strategic Communications for Design & Architecture"
  description={mission}
>
  <main class="canvas-wrapper">
    <!-- COLUMN 1: Brand Pane -->
    <div class="canvas-column pane-brand active">
      <div class="pane-tab-handle">
        <span class="handle-num">01</span>
        <span class="handle-title">Firm</span>
        <span class="handle-line"></span>
      </div>
      
      <div class="pane-content-area">
        <div class="brand-center-wrapper">
          <div class="brand-services-list">
            PUBLIC RELATIONS // BRAND STRATEGY // CREATIVE SERVICES // CONTENT CREATION
          </div>
          <div class="brand-content">
            <h1 class="main-headline">{headline}</h1>
            <p class="main-mission">{mission}</p>
          </div>
        </div>

        <div class="brand-meta">
          <p class="meta-label">Est. 2002 // New York City</p>
        </div>
      </div>
    </div>

    <!-- COLUMN 2: Selected Work Pane (Dynamic Circular Image Reveal on Hover) -->
    <div class="canvas-column pane-work">
      <div class="pane-tab-handle">
        <span class="handle-num">02</span>
        <span class="handle-title">Portfolio</span>
        <span class="handle-line"></span>
      </div>

      <div class="pane-content-area portfolio-split-layout">
        <!-- SVG Connector Line Overlay -->
        <svg class="portfolio-connector-svg" id="portfolio-connector-svg">
          <defs>
            <marker
              id="arrowhead"
              viewBox="0 0 10 10"
              refX="8"
              refY="5"
              markerWidth="6"
              markerHeight="6"
              orient="auto-start-reverse"
            >
              <path d="M 0 2 L 8 5 L 0 8 z" fill="var(--header-color)" />
            </marker>
          </defs>
          <path
            id="connector-path"
            fill="none"
            stroke="var(--header-color)"
            stroke-width="1.5"
            stroke-linejoin="round"
            stroke-linecap="round"
            marker-end="url(#arrowhead)"
          />
        </svg>

        <!-- Left Side: Content Menu -->
        <div class="portfolio-left-col">
          <div class="pane-header">
            <p class="eyebrow">Projects</p>
            <h2 class="pane-title">Selected Work</h2>
          </div>

          <div class="work-menu">
            {caseStudies.map((study) => (
              <a 
                href={`/work/${study.slug}`} 
                class="work-menu-link" 
                data-project-hover={study.slug}
                data-cursor="view"
              >
                <span class="project-tag">{study.discipline}</span>
                <span class="project-name">{study.title}</span>
              </a>
            ))}
          </div>

          <div class="pane-footer">
            <p class="all-work-btn">Selected Case Studies Menu</p>
          </div>
        </div>

        <!-- Right Side: Circular Project Image Display -->
        <div class="portfolio-right-col">
          {caseStudies.map((study) => (
            <div 
              class="portfolio-circular-frame" 
              id={`frame-${study.slug}`}
            >
              <img src={study.hero.src} alt={study.title} class="portfolio-circular-image" />
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- COLUMN 3: Expertise Pane (Hover Accordion) -->
    <div class="canvas-column pane-services">
      <div class="pane-tab-handle">
        <span class="handle-num">03</span>
        <span class="handle-title">Capabilities</span>
        <span class="handle-line"></span>
      </div>

      <div class="pane-content-area poster-layout">
        <div class="services-poster">
          {services.map((service, i) => (
            <div class="poster-line" data-poster-idx={i}>
              <div class="poster-line-inner">
                <h3 class="poster-title">{service.title}</h3>
                <span class="poster-id">{service.id}</span>
              </div>
              <p class="poster-desc">{service.body}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- COLUMN 4: Biography Pane -->
    <div class="canvas-column pane-bio">
      <div class="pane-tab-handle">
        <span class="handle-num">04</span>
        <span class="handle-title">Principal</span>
        <span class="handle-line"></span>
      </div>

      <div class="pane-content-area bio-split-layout">
        <!-- Left Side: Bio text and affiliations -->
        <div class="bio-left-col">
          <div class="pane-header">
            <p class="eyebrow">The Founder</p>
            <h2 class="pane-title">Elizabeth Kubany</h2>
          </div>

          <div class="bio-text-block">
            <p class="bio-teaser-text">{bioLead}</p>
            {bioRest.map((p) => (
              <p class="bio-paragraph">{p}</p>
            ))}
          </div>

          <div class="boards-box">
            <p class="boards-title">[ BOARD_AFFILIATIONS ]</p>
            <ul class="boards-list">
              {boards.map(b => (
                <li class="board-item">{b}</li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Right Side: Frame and Image -->
        <div class="bio-right-col">
          <div class="bio-teaser">
            <span class="image-annotation">[ LIZ_KUBANY // STUDIO_ONE ]</span>
            <div class="bio-image-wrapper hover-zoom">
              <img src="/assets/elizabeth-studio-one.jpg" alt="Elizabeth Kubany" />
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- COLUMN 5: Connect Pane -->
    <div class="canvas-column pane-contact">
      <div class="pane-tab-handle">
        <span class="handle-num">05</span>
        <span class="handle-title">Connect</span>
        <span class="handle-line"></span>
      </div>

      <div class="pane-content-area connect-split-layout">
        <!-- Left Column: Contact Form -->
        <div class="connect-left-col">
          <div class="pane-header">
            <p class="eyebrow">Inquiries</p>
            <h2 class="pane-title">Get In Touch</h2>
          </div>

          <p class="connect-lede">We'd love to hear about your project. Let's start the conversation.</p>

          <form class="contact-form" id="contact-form">
            <div class="form-group">
              <label for="form-name">Name</label>
              <input type="text" id="form-name" name="name" required placeholder="Name" />
            </div>
            <div class="form-group">
              <label for="form-email">Email</label>
              <input type="email" id="form-email" name="email" required placeholder="Email" />
            </div>
            <div class="form-group">
              <label for="form-subject">Subject</label>
              <input type="text" id="form-subject" name="subject" required placeholder="Subject" />
            </div>
            <div class="form-group">
              <label for="form-message">Message</label>
              <textarea id="form-message" name="message" rows="4" required placeholder="Message"></textarea>
            </div>
            <button type="submit" class="form-submit-btn" data-cursor="view">
              <span>Send Message</span>
              <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>
            <div class="form-status-msg" id="form-status"></div>
          </form>
        </div>

        <!-- Right Column: Instagram Feed & details -->
        <div class="connect-right-col">
          <div class="instagram-section-header">
            <span class="connect-annotation">[ @ELIZABETHKUBANY ]</span>
            <a href="https://www.instagram.com/elizabethkubany/" target="_blank" rel="noopener noreferrer" class="instagram-header-link" data-cursor="view">View Feed &rarr;</a>
          </div>

          <div class="instagram-grid">
            <a href="https://www.instagram.com/elizabethkubany/" target="_blank" rel="noopener noreferrer" class="instagram-item hover-zoom" data-cursor="view">
              <div class="instagram-img-wrapper">
                <img src="/assets/instagram-1.jpg" alt="Elizabeth Kubany Instagram Post" />
                <div class="instagram-item-overlay">
                  <span>♥ 142</span>
                </div>
              </div>
            </a>
            <a href="https://www.instagram.com/elizabethkubany/" target="_blank" rel="noopener noreferrer" class="instagram-item hover-zoom" data-cursor="view">
              <div class="instagram-img-wrapper">
                <img src="/assets/instagram-2.jpg" alt="Elizabeth Kubany Instagram Post" />
                <div class="instagram-item-overlay">
                  <span>♥ 98</span>
                </div>
              </div>
            </a>
            <a href="https://www.instagram.com/elizabethkubany/" target="_blank" rel="noopener noreferrer" class="instagram-item hover-zoom" data-cursor="view">
              <div class="instagram-img-wrapper">
                <img src="/assets/instagram-3.jpg" alt="Elizabeth Kubany Instagram Post" />
                <div class="instagram-item-overlay">
                  <span>♥ 215</span>
                </div>
              </div>
            </a>
            <a href="https://www.instagram.com/elizabethkubany/" target="_blank" rel="noopener noreferrer" class="instagram-item hover-zoom" data-cursor="view">
              <div class="instagram-img-wrapper">
                <img src="/assets/instagram-4.jpg" alt="Elizabeth Kubany Instagram Post" />
                <div class="instagram-item-overlay">
                  <span>♥ 176</span>
                </div>
              </div>
            </a>
          </div>

          <div class="connect-cta-block">
            <span class="connect-annotation">[ FOLLOW ]</span>
            <div class="connect-socials">
              <a href="https://www.instagram.com/elizabethkubany/" target="_blank" rel="noopener noreferrer" class="connect-social-link" data-cursor="view">Instagram</a>
              <span class="connect-divider">/</span>
              <a href="https://www.linkedin.com/in/lizkubany/" target="_blank" rel="noopener noreferrer" class="connect-social-link" data-cursor="view">LinkedIn</a>
            </div>
          </div>

          <div class="connect-meta">
            <p class="connect-location">&copy; 2026 KUBANY, LLC</p>
            <p class="connect-est">Site by <a href="mailto:ben@switchpartners.co" class="connect-credit-link" target="_blank" rel="noopener noreferrer" data-cursor="view">Switch Partners</a></p>
          </div>
        </div>
      </div>
    </div>

    <!-- COLUMN 6: Specs Pane -->
    <div class="canvas-column pane-specs">
      <div class="pane-tab-handle">
        <span class="handle-num">06</span>
        <span class="handle-title">Specs</span>
        <span class="handle-line"></span>
      </div>

      <div class="pane-content-area specs-split-layout">
        <!-- Sidebar: Aesthetic System -->
        <aside class="specs-sidebar">
          <div class="specs-header">
            <span class="sheet-number">Doc-01</span>
            <h2 class="sheet-title">Site Concept</h2>
            <p class="sheet-subtitle">Proposal by Switch Partners</p>
            <div class="header-stamp">
              <span>Spec-V1</span>
            </div>
          </div>

          <div class="sheet-section">
            <h3 class="section-title"><span>01</span> Aesthetic System</h3>
            
            <div class="palette-container">
              <h4 class="subsection-title">[ Brand Palette ]</h4>
              <ul class="palette-list">
                <li class="palette-item">
                  <span class="color-swatch cream" style="background: #FDFBF7; border: 1.5px solid rgba(61, 82, 69, 0.25);"></span>
                  <div class="color-details">
                    <span class="color-name">Cream</span>
                    <span class="color-hex">#FDFBF7</span>
                    <span class="color-use">Primary Background</span>
                  </div>
                </li>
                <li class="palette-item">
                  <span class="color-swatch sage" style="background: #3D5245;"></span>
                  <div class="color-details">
                    <span class="color-name">Deep Olive Sage</span>
                    <span class="color-hex">#3D5245</span>
                    <span class="color-use">Headers & Accents</span>
                  </div>
                </li>
                <li class="palette-item">
                  <span class="color-swatch sand" style="background: #B5AB91;"></span>
                  <div class="color-details">
                    <span class="color-name">Sand Accent</span>
                    <span class="color-hex">#B5AB91</span>
                    <span class="color-use">Meta & Secondary Labeling</span>
                  </div>
                </li>
                <li class="palette-item">
                  <span class="color-swatch charcoal" style="background: #2D302E;"></span>
                  <div class="color-details">
                    <span class="color-name">Charcoal</span>
                    <span class="color-hex">#2D302E</span>
                    <span class="color-use">Primary Body Text</span>
                  </div>
                </li>
              </ul>
            </div>

            <div class="typography-container">
              <h4 class="subsection-title">[ Typography ]</h4>
              <ul class="typography-list">
                <li>
                  <strong>Serif:</strong>
                  <span>Fraunces</span>
                  <p class="font-preview serif-preview">Selected work and primary headers</p>
                </li>
                <li>
                  <strong>Sans-Serif:</strong>
                  <span>Outfit</span>
                  <p class="font-preview sans-preview">Body text, navigation handles, lists</p>
                </li>
                <li>
                  <strong>Monospace:</strong>
                  <span>Fira Code</span>
                  <p class="font-preview mono-preview">[ Meta labels & indices ]</p>
                </li>
              </ul>
            </div>
          </div>
        </aside>

        <!-- Main Content: Interactive Features, Tech Stack, & Milestones -->
        <div class="specs-main">
          <!-- 2. Interactive Mechanics -->
          <div class="sheet-section">
            <h3 class="section-title"><span>02</span> Interactive Mechanics</h3>
            <div class="feature-grid">
              <div class="feature-card">
                <h5>Horizontal Folder Folio (Desktop)</h5>
                <p>Structure compiles into 6 interactive folders. Panes expand horizontally on click/URL deep-link parameters, compressing inactive panes into vertical title headers with smooth cubic-bezier transitions.</p>
              </div>
              <div class="feature-card">
                <h5>Orthogonal Hover Connector (Desktop Portfolio)</h5>
                <p>Hovering over active case study items triggers an SVG path calculation, drawing dynamic path connectors from the hovered text link directly to the circular image preview target.</p>
              </div>
              <div class="feature-card">
                <h5>Case Study Overlay Modals</h5>
                <p>Projects mount dynamically inside page overlays with a backdrop blur filter. Features fully integrated keyboard events (Escape key closes, Left/Right arrow keys slide between projects) and fixed dismiss anchors.</p>
              </div>
              <div class="feature-card">
                <h5>Sticky Spines Layout (Mobile)</h5>
                <p>For responsive displays, the horizontal folders convert to vertically stacked column headers that stick to the viewport header dynamically during page scroll.</p>
              </div>
            </div>
          </div>

          <!-- 3. Technology Stack -->
          <div class="sheet-section">
            <h3 class="section-title"><span>03</span> Technology Stack</h3>
            <div class="table-wrapper">
              <table class="stack-table">
                <thead>
                  <tr>
                    <th>Layer</th>
                    <th>Technology Selection</th>
                    <th>Core Function</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td><strong>Core Engine</strong></td>
                    <td><span class="tag">Astro Framework</span></td>
                    <td>Compiles pages to highly optimized static HTML with zero client-side JavaScript by default.</td>
                  </tr>
                  <tr>
                    <td><strong>Styling</strong></td>
                    <td><span class="tag">Vanilla CSS Variables</span></td>
                    <td>Defines centralized layout dimensions, brand theme systems, and responsive clamp sizes.</td>
                  </tr>
                  <tr>
                    <td><strong>Routing & State</strong></td>
                    <td><span class="tag">Vanilla TS / JS API</span></td>
                    <td>Coordinates fluid DOM transitions, modal navigation states, and URL parameters.</td>
                  </tr>
                  <tr>
                    <td><strong>Deployment</strong></td>
                    <td><span class="tag">Vercel Integration</span></td>
                    <td>Auto-builds on git push triggers, serving static assets via global edge content delivery network.</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>

          <!-- 4. Production Timeline -->
          <div class="sheet-section">
            <h3 class="section-title"><span>04</span> Production Timeline</h3>
            <div class="timeline">
              <div class="timeline-item">
                <span class="timeline-step">01</span>
                <div class="timeline-content">
                  <h6>Accordion Base Architecture</h6>
                  <p>Engineered the single-page horizontal accordion container layout. Programmed the customized preloader screen and vectorized SVG splash asset animation.</p>
                </div>
              </div>
              <div class="timeline-item">
                <span class="timeline-step">02</span>
                <div class="timeline-content">
                  <h6>Portfolio Grid & Connector Assets</h6>
                  <p>Rendered responsive connector lines on hover using math-calculated vector target coordinates. Established high-fidelity static folder sections and portfolio circular preview layout.</p>
                </div>
              </div>
              <div class="timeline-item">
                <span class="timeline-step">03</span>
                <div class="timeline-content">
                  <h6>Section Refinement & Brand Layout</h6>
                  <p>Upgraded biography container, expertise lists layout, board affiliation systems, and secondary content blocks.</p>
                </div>
              </div>
              <div class="timeline-item">
                <span class="timeline-step">04</span>
                <div class="timeline-content">
                  <h6>Overlay Modals & Accessibility Suites</h6>
                  <p>Transferred separate detail pages to interactive overlay views. Added modal accessibility, blur overlays, and keyboard listener loops.</p>
                </div>
              </div>
              <div class="timeline-item">
                <span class="timeline-step">05</span>
                <div class="timeline-content">
                  <h6>Mobile Optimization & Cleanup</h6>
                  <p>Constructed the mobile sticky spines system. Integrated the active social feeds, global cleanups, and eliminated duplicated elements.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- CASE STUDY MODAL OVERLAYS -->
  <div slot="overlays">
    {caseStudies.map((study, index) => {
      const nextStudy = caseStudies[(index + 1) % caseStudies.length];
      return (
        <div class="case-study-overlay" id={`overlay-${study.slug}`}>
          <div class="overlay-card">
            <button class="overlay-close-btn" data-close-overlay aria-label="Close Case Study">&times;</button>
            <div class="overlay-inner">
              
              <header class="overlay-header">
                <div class="overlay-meta-row">
                  <span class="discipline-tag">{study.discipline}</span>
                  {study.year && <span class="year-tag">{study.year}</span>}
                </div>
                <h1 class="project-title">{study.title}</h1>
              </header>

              <div class="overlay-content-grid">
                <!-- Left Column: Specs -->
                <div class="overlay-grid-left">
                  <div class="overlay-spec-group">
                    <span class="spec-label">[ ROLE_DEFINED ]</span>
                    <p class="spec-value">{study.role}</p>
                  </div>
                  
                  {study.coverage && study.coverage.length > 0 && (
                    <div class="overlay-spec-group">
                      <span class="spec-label">[ COVERAGE_HIGHLIGHTS ]</span>
                      <ul class="coverage-spec-list">
                        {study.coverage.map((outlet) => (
                          <li class="coverage-spec-item">{outlet}</li>
                        ))}
                      </ul>
                    </div>
                  )}
                </div>

                <!-- Right Column: Narrative & Media -->
                <div class="overlay-grid-right">
                  <!-- Hero Image -->
                  <div class="overlay-hero-wrapper hover-zoom">
                    <span class="overlay-image-annotation">[ HERO_FRAME ]</span>
                    <img src={study.hero.src} alt={study.hero.alt} />
                  </div>

                  <!-- Lede Summary -->
                  <div class="overlay-lede-block">
                    <span class="overlay-section-label">[ SEC. 01 // OVERVIEW ]</span>
                    <p class="overlay-lede-text">{study.summary}</p>
                  </div>

                  <!-- Narrative Narrative Body -->
                  <div class="overlay-narrative-body">
                    {study.body.map((paragraph) => (
                      <p class="overlay-narrative-p">{paragraph}</p>
                    ))}
                  </div>

                  <!-- Press Gallery -->
                  {study.gallery && study.gallery.length > 0 && (
                    <div class="overlay-gallery-section">
                      <span class="overlay-section-label">[ SEC. 02 // PRESS_GALLERY ]</span>
                      <div class="overlay-gallery-grid">
                        {study.gallery.map((img) => (
                          <figure class="overlay-gallery-item">
                            <div class="overlay-gallery-img-wrapper hover-zoom">
                              <img src={img.src} alt={img.alt} loading="lazy" />
                            </div>
                            {img.caption && <figcaption class="overlay-gallery-caption">{img.caption}</figcaption>}
                          </figure>
                        ))}
                      </div>
                    </div>
                  )}

                  <!-- Bottom Project Navigation -->
                  <div class="overlay-project-nav">
