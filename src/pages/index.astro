    opacity: 0.9;
    font-weight: 300;
  }

  /* Press Gallery */
  .overlay-gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.5rem;
  }

  .overlay-gallery-item {
    display: flex;
