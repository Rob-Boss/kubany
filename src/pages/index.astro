  /* Pinned Close Button */
  .overlay-close-btn {
    position: absolute;
    top: 2rem;
    right: 2rem;
    background: none;
    border: none;
    font-size: 3rem;
    line-height: 1;
    color: var(--header-color);
    cursor: pointer;
    z-index: 1010;
    opacity: 0.7;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .overlay-close-btn:hover {
    opacity: 1;
    transform: scale(1.1);
  }

  /* Header Section */
  .overlay-header {
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 2rem;
    margin-bottom: 3rem;
  }

  .overlay-meta-row {
    display: flex;
    gap: 1.5rem;
    font-family: var(--font-mono);
    font-size: var(--step--1);
